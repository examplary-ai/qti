{
  "name": "@examplary/qti",
  "description": "Utilities to generate and parse QTI 3.0 and 2.1 assessment packages.",
  "version": "1.5.0",
  "license": "MIT",
  "author": {
    "name": "Examplary AI",
    "email": "hi@examplary.ai",
    "url": "https://examplary.ai"
  },
  "homepage": "https://github.com/examplary-ai/qti#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/examplary-ai/qti.git"
  },
  "bugs": {
    "url": "https://github.com/examplary-ai/qti/issues"
  },
  "keywords": [
    "qti",
    "qti3",
    "qti-3",
    "qti2",
    "qti-2.1",
    "ims",
    "ims-manifest",
    "assessment",
    "exam",
    "education",
    "1edtech"
  ],
  "main": "dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "packageManager": "yarn@4.5.3",
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "prepublishOnly": "yarn build"
  },
  "lint-staged": {
    "*.{js,mjs,ts}": [
      "eslint --fix"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "cheerio": "^1.2.0",
    "jszip": "^3.10.1",
    "xmlbuilder2": "^4.0.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.19.17",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-no-only-tests": "^3.3.0",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.0",
    "vitest": "^4.1.5"
  }
}
